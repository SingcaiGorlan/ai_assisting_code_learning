# Documentation build output
# ============================================
web/docs/.vitepress/dist/
web/docs/.vitepress/cache/

# ============================================
# Database files
# ============================================
*.db
*.sqlite
*.sqlite3

# ============================================
# Temporary files
# ============================================
*.tmp
*.temp
*.bak
*.cache

# ============================================
